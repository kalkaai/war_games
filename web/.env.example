# Discord — full bot invite URL for the "Add Discord Bot" buttons
# Generate at: https://discord.com/developers/applications → OAuth2 → URL Generator
# Scopes: bot | applications.commands
NEXT_PUBLIC_DISCORD_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&scope=bot+applications.commands&permissions=0

# Google Analytics 4 — GA4 Measurement ID
# Find at: GA4 → Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense — Publisher client ID
# Find at: AdSense → Account → Account information → Publisher ID
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXX
